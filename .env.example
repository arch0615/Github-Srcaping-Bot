# Copy to .env and fill in.  Never commit your real .env.

# GitHub Personal Access Token (classic or fine-grained, read-only is enough).
# Create at: https://github.com/settings/tokens  — no scopes needed for public data.
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# PostgreSQL connection.  Matches the included docker-compose.yml defaults.
DATABASE_URL=postgresql://ghscraper:ghscraper@localhost:5432/ghscraper

# --- Search scope ---------------------------------------------------------
# Only accounts created on/after this date (the whole point of the task).
START_DATE=2021-01-01
# Leave END_DATE blank to use "today".
END_DATE=

# Optional extra GitHub search qualifiers, space-separated.
# Examples:  location:Berlin   language:Python   followers:>5   repos:>1
# Leave blank for the broadest sweep (date-only).
EXTRA_QUALIFIERS=

# Stop after collecting this many personal-email users (0 = unlimited).
MAX_USERS=0

# --- Web dashboard exposure ------------------------------------------------
# Interface to bind. 0.0.0.0 = reachable from other machines (public IP);
# 127.0.0.1 = this machine only. Port defaults to 8000.
HOST=0.0.0.0
PORT=8000
# STRONGLY recommended when HOST is not 127.0.0.1: set a username + password to
# password-protect the dashboard (it holds personal emails and can send mail).
# Leave blank to disable auth (NOT advised on a public IP).
DASH_USER=
DASH_PASS=

# --- Outreach (sending messages from your own domain) ---------------------
# SMTP server for your domain.  Examples:
#   Google Workspace : smtp.gmail.com   port 587  (use an App Password)
#   Zoho Mail        : smtp.zoho.com    port 465
#   Namecheap/Private: mail.privateemail.com port 465
# If any of HOST/USER/PASS/FROM_EMAIL is blank, sending runs in DRY_RUN mode
# (nothing is actually emailed — attempts are logged as 'skipped').
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=you@yourdomain.com
SMTP_PASS=
# Address recipients see (defaults to SMTP_USER) and the display name.
FROM_EMAIL=you@yourdomain.com
FROM_NAME=Your Name
# Seconds to wait between messages (throttle to stay off spam lists).
SEND_DELAY=8
# Set to 1 to force-simulate even when SMTP is configured.
DRY_RUN=
